{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebSearch|WebFetch",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/suggest-research.sh" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/enforce-toolkit-workflow.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/lint-md.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/validate-mmd.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-links.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/humanize-report-dates.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/compression-report.sh" }
        ]
      }
    ]
  }
}
